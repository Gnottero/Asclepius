{
	"schemaVersion": 1,
	"id": "asclepius",
	"version": "${version}",
	"name": "Asclepius Features",
	"description": "Powerful features and tools for the Asclepius project.",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/asclepius/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.gnottero.asclepius.Asclepius"
		],
		"client": [
			"com.gnottero.asclepius.AsclepiusClient"
		],
		"fabric-datagen": [
			"com.gnottero.asclepius.datagen.AsclepiusDataGenerator"
		]
	},
	"mixins": [
		"asclepius-features.mixins.json",
		{
			"config": "asclepius-features.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}